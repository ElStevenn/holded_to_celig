# ==================== REDIS CONFIGURATION ====================
# Redis connection URL
# For Docker: redis://redis:6379/0
# For local development: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ==================== AUTHENTICATION ====================
# Basic authentication credentials (if using basic auth)
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=12345

# Session secret key - CRITICAL for session persistence!
# MUST be set to a fixed value, otherwise sessions will be invalidated on app restart
# Generate a secure key with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Example: SECRET_KEY=a1b2c3d4e5f6...64characters...
SECRET_KEY=your-secret-key-here

# Session lifetime in seconds
# Default: 2592000 (30 days)
# Examples:
#   - 3600 = 1 hour
#   - 86400 = 1 day
#   - 604800 = 7 days
#   - 2592000 = 30 days
SESSION_LIFETIME_SECONDS=2592000

# ==================== AUTO-MIGRATION CONFIGURATION ====================
# Enable or disable automatic invoice migration
# Values: true or false
AUTO_MIGRATION_ENABLED=true

# Interval in days for automatic migration
# Default: 30 (runs every 30 days)
# Examples:
#   - 15 = every 15 days
#   - 30 = every month (approximately)
#   - 60 = every 2 months
AUTO_MIGRATION_INTERVAL_DAYS=30

# ==================== NOTES ====================
# - After changing AUTO_MIGRATION_* variables, restart Celery Beat: make restart-beat
# - The migration runs at midnight (00:00) every N days
# - You can also trigger migrations manually from the web interface

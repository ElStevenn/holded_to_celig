# Redis
# En Docker usa redis://redis:6379/0
# En local redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Login de la app
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=12345

# Clave para las sesiones - si no la pones fija, cada vez que reinicies tendrás que volver a loguearte
# Para generar una: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=pon-aqui-tu-clave-secreta

# Duración de la sesión en segundos (2592000 = 30 días)
SESSION_LIFETIME_SECONDS=2592000

# Migración automática
# true/false para activarla o no
AUTO_MIGRATION_ENABLED=true

# Cada cuántos días se ejecuta (30 = aprox cada mes)
AUTO_MIGRATION_INTERVAL_DAYS=30

# Si cambias lo de arriba, reinicia celery beat: make restart-beat
# La migración corre a medianoche. También puedes lanzarla a mano desde la web
